%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
%% cvstyle.sty
%%
%% Layout and formatting for cv.tex, factored out of the main document.
%% Adapted from Theodore P. Pavlic's "Simple LaTeX CV Template"
%% (CC BY-NC 3.0 US, http://creativecommons.org/licenses/by-nc/3.0/us/).
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{cvstyle}

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%% Packages %%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

\RequirePackage[numbers]{natbib} % formatted citations in text

% Bold my own name wherever it appears in an author list
\RequirePackage{xstring}
\def\FormatName#1{%
  \IfSubStr{#1}{Linderman}{\textbf{#1}}{#1}%
}

% bibentry, with the standard fix for its clash with hyperref
\RequirePackage{bibentry}
\makeatletter\let\saved@bibitem\@bibitem\makeatother

\RequirePackage{calc}      % math inside length specifications
\RequirePackage{amssymb}
\RequirePackage{array}     % tabular columns, used by \cvline
\RequirePackage{needspace} % keep a section heading with its first content

% Section titles as marginal notes, left of the body text
\reversemarginpar
\RequirePackage[paper=letterpaper,
            marginparwidth=1.25in,    % width of section titles
            marginparsep=.05in,      % space between titles and text
            margin=1in,
            includemp]{geometry}

\setlength{\parindent}{0in}
\RequirePackage[shortlabels]{enumitem}

% Page numbers as "N of LastPage", centered in the margin below the body
\RequirePackage{fancyhdr,lastpage}
\pagestyle{fancy}
\fancyhf{}\renewcommand{\headrulewidth}{0pt}
\fancyfootoffset{\marginparsep+\marginparwidth}
\newlength{\footpageshift}
\setlength{\footpageshift}
          {0.5\textwidth+0.5\marginparsep+0.5\marginparwidth-2in}
\lfoot{\hspace{\footpageshift}%
       \parbox{4in}{\, \hfill \arabic{page} of \protect\pageref*{LastPage} \hfill \,}}

\RequirePackage{hyperref}
\hypersetup{colorlinks,breaklinks,urlcolor=black}
\makeatletter\let\@bibitem\saved@bibitem\makeatother

%%%%%%%%%%%%%%%%%%%%%%%%%%%%% Heading %%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

% \makeheading[right_object]{name}: title block at the top of the CV,
% with an optional right-justified object (e.g. a title or photo)
% flush with the name.
\newcommand{\makeheading}[2][]%
        {\hspace*{-\marginparsep minus \marginparwidth}%
         \begin{minipage}[t]{\textwidth+\marginparwidth+\marginparsep}%
             {\LARGE \bfseries #2 \hfill #1}\\[-0.15\baselineskip]%
                 \rule{\columnwidth}{1pt}%
         \end{minipage}}

%%%%%%%%%%%%%%%%%%%%%%%%%%% Section headings %%%%%%%%%%%%%%%%%%%%%%%%%%%

% Flush left in small caps, down in the pseudo-margin. \needspace reserves
% room for the heading plus a few lines of what follows, so the heading
% is never left alone at the bottom of a page, orphaned from its content.
\renewcommand{\section}[1]{\needspace{5\baselineskip}%
    \pagebreak[3]%
    \hyphenpenalty=10000%
    \vspace{1.3\baselineskip}%
    \noindent\llap{\scshape\smash{\parbox[t]{\marginparwidth}{\raggedright #1}}}%
    \vspace{-\baselineskip}\par}

% Inline sub-headings within a section's body (e.g. "Books and Theses"
% under Publications). Half a line before and after, so a subsection
% that follows a list (every list below has zeroed topsep/partopsep
% and so leaves no trailing space of its own) ends up with just one
% half-line gap, not a stack of two.
\renewcommand{\subsection}[1]{\pagebreak[3]%
    \vspace{0.5\baselineskip}%
    \noindent{\small\scshape #1}\par
    \vspace{0.5\baselineskip}}

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%% Lists %%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

% Lets an outer-type list's items prefer a page break before the item,
% rather than splitting an item across pages (used by the lists below).
\newcommand*\fixouterlist[1]{%
    \expandafter\let\csname preFixOuterList#1\expandafter\endcsname\csname #1\endcsname
    \expandafter\def\csname #1\endcsname{\csname preFixOuterList#1\endcsname\let\oldItem\item\def\item{\pagebreak[2]\oldItem}}
    \expandafter\let\csname preFixOuterListend#1\expandafter\endcsname\csname end#1\endcsname
    \expandafter\def\csname end#1\endcsname{\let\item\oldItem\csname preFixOuterListend#1\endcsname}}

% outerlist: itemize with generous space between items. topsep and
% partopsep are zeroed (as in singlelist/pubslist) so the list needs
% no trailing correction: whatever follows supplies its own gap.
\newlist{outerlist}{itemize}{3}
    \setlist[outerlist]{label=\enskip\tiny$\square$,leftmargin=*,%
      topsep=0pt,partopsep=0pt}
    \fixouterlist{outerlist}

% singlelist: single-spaced itemize (no extra gap between items), for
% compact lists like Honors and Awards or Selected Talks. topsep and
% partopsep are already 0, so (unlike outerlist) it needs no trailing
% correction: whatever follows (a \subsection, or \section's own
% leading space) supplies its own gap instead of fighting this one.
\newlist{singlelist}{itemize}{3}
    \setlist[singlelist]{label=\enskip\tiny$\square$,leftmargin=*,%
      itemsep=0pt,parsep=0pt,topsep=0pt,partopsep=0pt}
    \fixouterlist{singlelist}

% pubslist: single-spaced itemize with a half-line gap between items,
% for the Publications section. Same reasoning as singlelist: no
% trailing correction needed since topsep/partopsep are already 0.
\newlist{pubslist}{itemize}{3}
    \setlist[pubslist]{label=\enskip\tiny$\square$,leftmargin=*,%
      itemsep=0.5\baselineskip,topsep=0pt,partopsep=0pt}
    \fixouterlist{pubslist}

%%%%%%%%%%%%%%%%%%%%%%%%%%%%% Dated entries %%%%%%%%%%%%%%%%%%%%%%%%%%%%

% \cvline{text}{years}: a CV entry with a year/date range set flush right
% in its own fixed-width column. Unlike right-aligning with \hfill in a
% paragraph, the date stays put even when the left-hand text wraps to a
% second line, so dates line up consistently across every section.
% Does not end with a forced linebreak: follow it with \\ when more
% lines come after it, or with nothing when it is the item's last line
% (a trailing \\ with nothing after it would leave a blank line).
%
% Built from a single-row tabular*, not two side-by-side \parbox[t]'s:
% a top-aligned \parbox reports its depth as everything below its FIRST
% line, so a wrapped second line inflates that depth, and the next
% list item's baseline (always exactly \baselineskip below the current
% one) ends up landing on top of it. A tabular row's own baseline
% comes from a strut, so wrapped text doesn't get treated as depth.
%
% The gap between the two columns uses \extracolsep{\fill}, not a bare
% \hfill: tabular*'s width-matching only stretches glue introduced via
% \extracolsep to hit the requested width exactly. A plain @{\hfill}
% is inserted at its natural (zero) width and never stretched, so the
% whole row quietly comes up \cvcolsep short of \linewidth and the
% date column sits that far short of the right margin.
\newlength{\cvdatewidth}\setlength{\cvdatewidth}{1.3in}
\newlength{\cvcolsep}\setlength{\cvcolsep}{0.15in}
\newcommand{\cvline}[2]{%
  \noindent\begin{tabular*}{\linewidth}[t]{@{}p{\dimexpr\linewidth-\cvdatewidth-\cvcolsep\relax}@{\extracolsep{\fill}}p{\cvdatewidth}@{}}
  \raggedright #1 & \raggedleft\small #2
  \end{tabular*}}

% \grant[role]{title}{funding agency}{award period}{PI line}: one
% Research Support entry in a consistent shape. The PI line is passed
% through as-is (e.g. "Contact PI: S. Linderman" or "Lead PI: T.
% Gerstenberg (Stanford)") since which label applies is meaningful and
% varies by grant. The optional role (e.g. PI, MPI, Co-PI, Co-I) is
% omitted entirely, rather than left blank, when a grant has none.
\newcommand{\grant}[5][]{%
  #2\\
  Funding Agency: #3\\
  Award Period: #4\\
  #5%
  \IfBlankTF{#1}{}{\\Role: #1}}

\endinput
